# ============================================
# 5G-A 工业智能调度平台 - 环境配置
# ============================================

# 应用环境: development / testing / production
FLASK_ENV=development

# MySQL数据库配置
# 请修改 DB_PASSWORD 为你本机MySQL的root密码
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=486908
DB_NAME=5g_a_industry

# 如果MySQL 8.0使用caching_sha2_password认证，连接会自动处理
# 如果遇到认证问题，可在MySQL中执行:
# ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '你的密码';

# 数据库连接URI (自动拼接)
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:root@127.0.0.1:3306/5g_a_industry

# 安全配置
SECRET_KEY=5g-a-industry-scheduling-platform-2026
JWT_SECRET_KEY=5g-a-jwt-secret-key-2026

# DeepSeek API配置
DEEPSEEK_API_KEY=
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 日志配置
LOG_LEVEL=DEBUG